# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# # --- Docs ---
# _docs/
# _docs/*

# --- Virtual environments ---
.venv/
venv/
env/

# --- uv ---
# uv.lock IS committed (reproducible installs) — do not ignore it.

# --- Environment files (never commit real secrets) ---
# Only one env file exists: .env (local dev only). Production has no env
# file at all — Azure injects real env vars (incl. Key Vault references).
.env

# --- Testing / coverage ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.mypy_cache/
.ruff_cache/

# --- IDE ---
.vscode/
.idea/
*.swp

# --- OS ---
.DS_Store
Thumbs.db

# --- Logs ---
*.log

# --- Alembic (keep versions/, ignore local sqlite if ever used) ---
*.sqlite3

# --- Docker ---
docker-compose.override.yml

# --- Terraform ---
.terraform/
.terraform.*
