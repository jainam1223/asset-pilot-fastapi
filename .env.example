# Copy to .env.development / .env.staging / .env.production and fill in
# real values. This file documents every setting; it must never contain
# real secrets. In Azure, production values are injected as real env vars
# (App Service / Container Apps settings or Key Vault references) — this
# file is a local-dev convenience only, not a production requirement.

# --- Core / environment ---
ENVIRONMENT=development            # development | staging | production | test
APP_NAME=asset-pilot-fastapi
APP_VERSION=0.1.0
DEBUG=true

# --- API ---
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# --- CORS / middleware ---
CORS_ALLOW_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]
TRUSTED_HOSTS=["*"]
GZIP_MIN_SIZE=500

# --- Database (PostgreSQL via SQLAlchemy async + asyncpg) ---
# Single required connection string — no Postgres container is run by
# docker-compose. host.docker.internal reaches your host machine's
# Postgres from inside the api container (works via the extra_hosts
# entry in docker-compose.yml on Linux; native on Docker Desktop). Use
# `localhost` instead if you run the app outside Docker too. For a
# distributed/managed Postgres, just swap the whole string (encode SSL
# in the query string, e.g. `?ssl=require`).
DATABASE_URL=postgresql+asyncpg://username:user_password@localhost:5432/asset_pilot_db
DATABASE_URL_SYNC=postgresql://username:user_password@localhost:5432/asset_pilot_db 

DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
DATABASE_ECHO=false

# --- Redis ---
# Same pattern as DATABASE_URL: set REDIS_URL directly, or use the
# discrete fields. Azure Cache for Redis needs REDIS_SSL=true (rediss://).
# REDIS_URL=rediss://:password@host:6380/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SSL=false
REDIS_SOCKET_TIMEOUT=5.0
REDIS_MAX_CONNECTIONS=20

# --- JWT / security ---
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080
JWT_ISSUER=asset-pilot-fastapi

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=false                     # forced true automatically for staging/production

# --- Pagination defaults ---
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# --- Health checks ---
HEALTH_CHECK_TIMEOUT_SECONDS=2.0

# --- Rate limiting (plumbing only, not enforced yet) ---
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# --- Future AI chatbot module (placeholder, unused today) ---
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL_NAME=
LLM_REQUEST_TIMEOUT_SECONDS=30.0

# --- Local dev tooling (docker-compose only) ---
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
